# spectroscope reads its configuration from settings files; the environment is the
# BASE layer directly above the defaults — anything a settings file states
# wins over it (env is the base, settings call the shots).
# Precedence: defaults < env < ~/.spectro/settings.json
#             < .spectro/settings.json (launch dir, deprecated)
#             < <workspace>/.spectro/settings.json < <workspace>/.spectro/settings.local.json
#             < CLI flags
# This file is for SECRETS. Every SPECTRO_* variable still works as the env
# base, but is deprecated in favor of its settings field — `spectro doctor`
# names each one that is set AND shadowed. Field mapping: see the
# configuration chapter (USER-GUIDE ch. 30) or docs/ARCHITECTURE.md §3.

ANTHROPIC_API_KEY=

# Web search Tavily tier (keyless DuckDuckGo fallback without it):
# TAVILY_API_KEY=

# Image generation backends:
# GEMINI_API_KEY=
# OPENAI_API_KEY=            # also the openai chat provider's key
